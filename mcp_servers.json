{
  "_comment": "Configure MCP servers here. Remove this _comment key before use.",
  "_docs": "https://modelcontextprotocol.io/docs/tools/servers",

  "filesystem": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-filesystem", "./workspace"],
    "transport": "stdio"
  },

  "github": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-github"],
    "transport": "stdio",
    "env": {
      "GITHUB_TOKEN": "ghp_your_token_here"
    }
  },

  "brave-search": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-brave-search"],
    "transport": "stdio",
    "env": {
      "BRAVE_API_KEY": "your_brave_api_key"
    }
  }
}
