# Copy this file to .env and fill in values.
# The server does not load .env automatically — export variables manually
# or use `source .env` / a tool like direnv.

# ── LLM (required for model-backed planning and memory extraction) ─────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Model selection (optional) ─────────────────────────────────────────────
# Default: claude-haiku-4-5-20251001
# ASSISTANT_MODEL=claude-haiku-4-5-20251001

# ── Planner mode (optional) ────────────────────────────────────────────────
# Force heuristic routing regardless of API key (useful for CI / offline use)
# PLANNER_MODE=heuristic

# ── Agent loop (optional) ──────────────────────────────────────────────────
# Maximum tool calls the agent will chain per turn (default: 10)
# AGENT_MAX_STEPS=10

# ── API auth (recommended for non-local deployments) ──────────────────────
# When set, all endpoints except /health require:
#   Authorization: Bearer <ASSISTANT_API_KEY>
# Also set the matching API_KEY in web/index.html.
# ASSISTANT_API_KEY=change-me-before-deploying

# ── CORS (set to your frontend URL in production) ─────────────────────────
# Default: * (open — local dev only)
# ALLOWED_ORIGIN=https://your-frontend.com
